# Copy this file to .env on the server, then fill in real values:
#   cp .env.production.example .env && nano .env

# ─── Domains (must point to this server's IP in DNS) ────────────────
OWN_DOMAIN=own.example.com
ADMIN_DOMAIN=admin.example.com

# ─── MySQL ──────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change-this-strong-root-password
MYSQL_DATABASE=pms_poolvilla
MYSQL_USER=pms
MYSQL_PASSWORD=change-this-strong-user-password

# ─── Auth.js (NextAuth) ─────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32
