// Prisma schema — PMS Pool Villa
// MVP: Owner panel only. Variant first-class. PlanetScale MySQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma" // PlanetScale: FK emulated at app layer
}

// ─────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  STAFF
  SUPER_ADMIN
}

enum PropertyReviewStatus {
  PENDING // submitted, awaiting admin review
  ACTIVE // approved + visible
  INACTIVE // owner toggled off
  REJECTED // admin rejected, needs revision
}

enum PoolOwnership {
  PRIVATE
  SHARED
}

enum PoolSystem {
  SALT
  CHLORINE
  SALT_WARM
  CHLORINE_WARM
  FRESH_WARM
}

enum DistanceTargetType {
  SEA
  WATERFALL
}

enum DistanceUnit {
  METER
  KILOMETER
}

enum PriceDisplayMode {
  SHOW_SELL
  SHOW_WHOLESALE
  HIDE
}

enum CalendarStatus {
  OPEN
  BOOKED
  PENDING_PAYMENT
  UNDER_MAINTENANCE
}

enum PriceOverrideType {
  SPECIAL // วันสำคัญ
  DISCOUNT // ลดราคา
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED
  AUTO_CANCELLED
}

enum BookingSource {
  OWNER_DIRECT
  PUBLIC_SALE_PAGE
  EXTERNAL_ICAL
}

enum PaymentMethod {
  TRANSFER
  CARD
  MOBILE_BANKING
}

enum OtaPlatform {
  AGODA
  BOOKING
  AIRBNB
  TRIP
  EXPEDIA
}

enum CouponType {
  DISCOUNT
  CASH
}

enum CouponFormat {
  PERCENT
  BAHT
}

enum AccountingDocType {
  QUOTE
  INVOICE
  TAX_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum HousekeepingStatus {
  PENDING
  DONE
}

// ─────────────────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String
  phone         String?
  role          UserRole  @default(OWNER)
  suspendedAt   DateTime? // when set, login is blocked
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties     Property[]
  hotels         Hotel[]
  payoutChannels PayoutChannel[]
  accountingDocs AccountingDoc[]
  saleSlug       String?         @unique // for /sale/[ownerSlug]

  // Auth.js
  accounts Account[]
  sessions Session[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────
// Lookups (master data, managed in m. panel)
// ─────────────────────────────────────────────────────────

model Location {
  id        String   @id @default(cuid())
  name      String // e.g. "พัทยา"
  province  String // e.g. "ชลบุรี"
  createdAt DateTime @default(now())

  zones      LocationZone[]
  properties PropertyLocation[]

  @@index([province])
}

model LocationZone {
  id         String @id @default(cuid())
  locationId String
  name       String // e.g. "เหนือ"

  location   Location           @relation(fields: [locationId], references: [id])
  properties PropertyLocation[]

  @@index([locationId])
}

model PropertyTypeMaster {
  id        String   @id @default(cuid())
  code      String   @unique // POOL_VILLA, LOFT, BNB, RESORT, ...
  nameTh    String
  nameEn    String?
  desc      String? // คำอธิบายสั้น
  iconRef   String? // icon name from @pms/ui (e.g., "swimmer", "couch")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AmenityMaster {
  id       String  @id @default(cuid())
  code     String  @unique // wifi, parking, bbq
  nameTh   String
  nameEn   String?
  nameZh   String?
  category String // facility | function
  iconRef  String? // PrimeNG icon name

  amenities PropertyAmenity[]
}

// ─────────────────────────────────────────────────────────
// Property + Variant (variant is first-class)
// ─────────────────────────────────────────────────────────

model Property {
  id           String               @id @default(cuid())
  code         String               @unique // CITY-44
  legacyCode   String? // รหัสเดิม
  ownerId      String
  name         Json // { th: "...", en: "...", zh: "..." } — MVP only `th` populated
  type         String // PropertyTypeMaster.code (POOL_VILLA, LOFT, BNB, ...)
  reviewStatus PropertyReviewStatus @default(PENDING)
  pricingMode  PriceDisplayMode     @default(SHOW_SELL)
  isActive     Boolean              @default(true)
  /// Owner-controlled toggle — when false, the property is hidden from the
  /// public Sale Page (/s/[slug]) regardless of isActive / reviewStatus.
  showOnSalePage Boolean            @default(true)

  // Top-level basics (also at variant level for split rooms)
  totalBedrooms  Int
  totalBathrooms Int
  areaSqwa       Decimal? @db.Decimal(8, 2) // ตารางวา (Thai unit)
  partnerListing Boolean  @default(false) // "ต้องการลงประกาศพาทเนอร์"
  /// Unit for agent / partner pricing — 'THB' = absolute baht, 'PERCENT' = % off the sell price.
  /// Only meaningful when partnerListing is true. Defaults to 'THB' so legacy rows stay correct.
  agentPriceUnit String   @default("THB")
  contactInfo    String? // "name 0987654321"
  /// How far in advance guests can book — null = use system default (vacant per weekly settings).
  /// Common values: 3, 6, 9, 12, 24 (months). 0 = closed.
  bookingWindowMonths Int? // months allowed for advance booking

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner    User              @relation(fields: [ownerId], references: [id])
  variants PropertyVariant[]
  images   PropertyImage[]
  pools    PropertyPool[]
  amenities PropertyAmenity[]
  policy   PropertyPolicy?
  location PropertyLocation?
  icals    PropertyIcal[]
  bookings Booking[]

  housekeepingTasks HousekeepingTask[]
  penaltyItems      PenaltyItem[]
  payoutChannels    PayoutChannelProperty[]

  // Multilang detail (rich content sec 3) — keep in subtables for clarity
  landmarks    PropertyLandmark[]
  shops        PropertyNearbyShop[]
  extraDetails PropertyExtraDetail[]

  @@index([ownerId])
  @@index([reviewStatus])
  @@index([deletedAt])
}

/// One Property has 1..N variants. Default variant = the whole villa.
/// Split-room mode: extra variants like "8 nights", "6 nights", etc.
model PropertyVariant {
  id         String  @id @default(cuid())
  propertyId String
  name       Json // { th: "8 ห้องนอน" }
  bedrooms   Int
  maxGuests  Int
  isDefault  Boolean @default(false) // เปิดทั้งหลัง = true; แบ่งห้อง = false
  sortOrder  Int     @default(0)

  // For split-rooms: pricing extra room
  extraRoomPrice Decimal? @db.Decimal(10, 2)
  // วิธีการเลือกห้องนอน: OWNER_ALLOCATES | GUEST_PICKS_AT_CHECKIN
  roomSelectionMode String? // null when not split

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property      Property              @relation(fields: [propertyId], references: [id])
  weeklyPricing VariantWeeklyPricing[]
  calendar      VariantCalendar[]
  bookings      Booking[]

  @@index([propertyId])
  @@index([propertyId, isDefault])
}

/// Default 7 rows per variant (Sun..Sat)
model VariantWeeklyPricing {
  id        String   @id @default(cuid())
  variantId String
  dayOfWeek Int // 0=Sun..6=Sat
  price     Decimal  @db.Decimal(10, 2)
  /// Optional partner/OTA price — shown only when Property.partnerListing is true
  agentPrice Decimal? @db.Decimal(10, 2)
  minStay   Int      @default(1)
  /// Per-day toggle: when false, this variant is locked for split-room sale on this DOW
  splitOpen Boolean  @default(true)
  /// Guests included in `price` (e.g. 12 = ราคา 9,900 รวม 12 ท่าน).
  /// Defaults to PropertyVariant.maxGuests on the server when null.
  includedGuests Int?
  /// Fee per additional guest above `includedGuests` (e.g. 500 = ท่านที่ 13+ คิดเพิ่ม 500/ท่าน).
  /// null/0 = ไม่คิดค่าท่านเพิ่ม (booker can never exceed PropertyVariant.maxGuests).
  extraGuestFee  Decimal? @db.Decimal(10, 2)

  variant PropertyVariant @relation(fields: [variantId], references: [id])

  @@unique([variantId, dayOfWeek])
  @@index([variantId])
}

/// Override-only storage. If row exists, it overrides weekly default.
/// Open + no override → no row.
model VariantCalendar {
  id                 String             @id @default(cuid())
  variantId          String
  date               DateTime           @db.Date
  status             CalendarStatus     @default(OPEN)
  priceOverride      Decimal?           @db.Decimal(10, 2)
  /// Per-day agent / OTA price override — trumps the weekly default agentPrice when set.
  agentPriceOverride Decimal?           @db.Decimal(10, 2)
  /// Snapshot of the regular price BEFORE this override — used to render the
  /// strikethrough original alongside a DISCOUNT promo price. Null for normal
  /// overrides where no comparison is needed.
  originalPrice      Decimal?           @db.Decimal(10, 2)
  /// Same as `originalPrice` but for the agent / OTA price. Captured when the
  /// owner transitions a day into the DISCOUNT tag so the agent-mode calendar
  /// can render strikethrough on the previous agent price too.
  originalAgentPrice Decimal?           @db.Decimal(10, 2)
  priceType          PriceOverrideType?
  note               String?            @db.Text
  bookingId          String?

  variant PropertyVariant @relation(fields: [variantId], references: [id])
  booking Booking?        @relation(fields: [bookingId], references: [id])

  @@unique([variantId, date])
  @@index([variantId, status])
  @@index([date])
  @@index([bookingId])
}

// ─────────────────────────────────────────────────────────
// Property sub-entities
// ─────────────────────────────────────────────────────────

model PropertyImage {
  id         String  @id @default(cuid())
  propertyId String
  // MediumText (16MB) — owners often paste data: URLs for high-res photos before any CDN
  // upload pipeline exists. MySQL TEXT (64KB) overflows for ~3MB+ images.
  url        String  @db.MediumText
  type       String // cover | gallery | tour_360
  category   String? // pool | bedroom | bathroom | living | kitchen | rooftop | outdoor
  sortOrder  Int     @default(0)

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId, type])
}

model PropertyLocation {
  propertyId             String   @id
  locationId             String
  zoneId                 String?
  province               String // denormalized for quick filter
  lat                    Decimal  @db.Decimal(10, 7)
  lng                    Decimal  @db.Decimal(10, 7)
  gmapUrl                String?  @db.Text
  address                String   @db.Text
  distanceTargetType     DistanceTargetType?
  distanceValue          Decimal? @db.Decimal(8, 2)
  distanceUnit           DistanceUnit?

  property Property      @relation(fields: [propertyId], references: [id])
  location Location      @relation(fields: [locationId], references: [id])
  zone     LocationZone? @relation(fields: [zoneId], references: [id])

  @@index([locationId])
  @@index([zoneId])
}

model PropertyPool {
  id         String        @id @default(cuid())
  propertyId String
  ownership  PoolOwnership
  system     PoolSystem
  widthM     Decimal?      @db.Decimal(6, 2)
  lengthM    Decimal?      @db.Decimal(6, 2)
  depthM     Decimal?      @db.Decimal(6, 2)
  features   Json // [kid_pool, slider, sea_view, ...]

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model PropertyAmenity {
  id              String @id @default(cuid())
  propertyId      String
  amenityMasterId String

  property Property      @relation(fields: [propertyId], references: [id])
  amenity  AmenityMaster @relation(fields: [amenityMasterId], references: [id])

  @@unique([propertyId, amenityMasterId])
  @@index([amenityMasterId])
}

model PropertyPolicy {
  propertyId           String   @id
  checkinStart         String // "14:00"
  checkinEnd           String? // "18:00"
  checkout             String // "11:00"
  deposit              Decimal  @db.Decimal(10, 2)
  cancellationPolicy   Json // { th, en, zh } rich text
  postponePolicy       Json
  houseRules           Json?
  // Extra guest policy
  maxGuests            Int
  extraAdultPrice      Decimal  @db.Decimal(10, 2)
  freeChildAgeUnder7   Int      @default(0)
  extraChildPrice      Decimal  @db.Decimal(10, 2)
  freeInfantAgeUnder2  Int      @default(0)
  // Pet policy
  maxPets              Int      @default(0)
  extraPetPrice        Decimal  @default(0) @db.Decimal(10, 2)

  property Property @relation(fields: [propertyId], references: [id])
}

model PropertyIcal {
  id         String      @id @default(cuid())
  propertyId String
  platform   OtaPlatform
  icalUrl    String      @db.Text
  lastSyncAt DateTime?
  createdAt  DateTime    @default(now())

  property Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, platform])
  @@index([propertyId])
}

model PropertyLandmark {
  id         String @id @default(cuid())
  propertyId String
  text       Json // { th, en, zh }
  sortOrder  Int    @default(0)

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model PropertyNearbyShop {
  id         String @id @default(cuid())
  propertyId String
  text       Json
  sortOrder  Int    @default(0)

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

model PropertyExtraDetail {
  id         String @id @default(cuid())
  propertyId String
  text       Json
  sortOrder  Int    @default(0)

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}

// ─────────────────────────────────────────────────────────
// Bookings
// ─────────────────────────────────────────────────────────

model Booking {
  id            String         @id @default(cuid())
  variantId     String
  propertyId    String // denorm for ownerId-scoped queries
  customerName  String
  customerPhone String?
  bookerName    String // อาจไม่เท่ากับ customerName (agent)
  guestCount    Int
  checkin       DateTime       @db.Date
  checkout      DateTime       @db.Date
  total         Decimal        @db.Decimal(10, 2)
  deposit       Decimal        @default(0) @db.Decimal(10, 2)
  source        BookingSource
  paymentMethod PaymentMethod?
  status        BookingStatus
  paymentDueAt  DateTime? // for auto-cancel
  publicNote    String?        @db.Text
  internalNote  String?        @db.Text
  couponId      String?

  // Invoice fields (filled when ทำใบจอง tab)
  invoiceVat        Boolean @default(false) // VAT 7% toggle
  invoiceShowLogo   Boolean @default(false)
  invoiceIssued     Boolean @default(false)
  invoiceIssuedAt   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  variant       PropertyVariant   @relation(fields: [variantId], references: [id])
  property      Property          @relation(fields: [propertyId], references: [id])
  coupon        Coupon?           @relation(fields: [couponId], references: [id])
  calendarCells VariantCalendar[]
  postpones     BookingPostpone[]

  @@index([variantId, checkin, checkout])
  @@index([propertyId])
  @@index([status, paymentDueAt])
  @@index([deletedAt])
}

model BookingPostpone {
  id            String   @id @default(cuid())
  bookingId     String
  oldCheckin    DateTime @db.Date
  oldCheckout   DateTime @db.Date
  // Nullable to support "ยังไม่ระบุวัน" — owner postpones without committing new
  // dates yet. The booking's original cells are released, but the booking sits in
  // history (ประวัติเลื่อนเข้าพัก) until new dates are chosen.
  newCheckin    DateTime? @db.Date
  newCheckout   DateTime? @db.Date
  postponedAt   DateTime @default(now())
  expiresAt     DateTime // หมดเขตเลื่อนวัน
  reason        String?  @db.Text

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

// ─────────────────────────────────────────────────────────
// Coupons
// ─────────────────────────────────────────────────────────

model Coupon {
  id             String       @id @default(cuid())
  ownerId        String // scoped per owner
  code           String
  name           String
  type           CouponType
  format         CouponFormat
  value          Decimal      @db.Decimal(10, 2)
  qty            Int
  qtyLeft        Int
  startsAt       DateTime
  expiresAt      DateTime
  perUser        Boolean      @default(false)
  assignedUserId String?

  bookings Booking[]

  @@unique([ownerId, code])
  @@index([ownerId])
}

// ─────────────────────────────────────────────────────────
// Accounting
// ─────────────────────────────────────────────────────────

model AccountingDoc {
  id          String            @id @default(cuid())
  ownerId     String
  type        AccountingDocType
  docNo       String
  customerData Json // { name, address, taxId, ... }
  items       Json // [{ desc, qty, price, total }, ...]
  subtotal    Decimal           @db.Decimal(12, 2)
  vat         Decimal           @default(0) @db.Decimal(12, 2)
  total       Decimal           @db.Decimal(12, 2)
  status      String // draft | issued | paid | cancelled
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  owner User @relation(fields: [ownerId], references: [id])

  @@unique([ownerId, type, docNo])
  @@index([ownerId, type])
}

// ─────────────────────────────────────────────────────────
// Payout
// ─────────────────────────────────────────────────────────

model PayoutChannel {
  id          String @id @default(cuid())
  ownerId     String
  bank        String
  accountName String
  accountNo   String

  owner      User                    @relation(fields: [ownerId], references: [id])
  properties PayoutChannelProperty[]

  @@index([ownerId])
}

model PayoutChannelProperty {
  payoutChannelId String
  propertyId      String

  channel  PayoutChannel @relation(fields: [payoutChannelId], references: [id])
  property Property      @relation(fields: [propertyId], references: [id])

  @@id([payoutChannelId, propertyId])
  @@index([propertyId])
}

// ─────────────────────────────────────────────────────────
// Housekeeping (LINE bot integration — Phase 4+)
// ─────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────
// System settings (singleton) + Service master (Phase M3)
// ─────────────────────────────────────────────────────────

model SystemSetting {
  id String @id @default("singleton")

  // Commission
  defaultCommissionPercent Decimal @default(10) @db.Decimal(5, 2)

  // Feature flags
  allowOwnerSelfPublish Boolean @default(true)
  enableMarketplace     Boolean @default(true)
  enableAutoCancel      Boolean @default(true)
  enableHousekeeping    Boolean @default(false)

  // Theme / branding
  brandName     String  @default("PMS Pool Villa")
  brandColorHex String  @default("#4f46e5")
  logoUrl       String? @db.Text

  updatedAt DateTime @updatedAt
}

model ServiceMaster {
  id        String   @id @default(cuid())
  code      String   @unique
  nameTh    String
  nameEn    String?
  category  String // bbq | transfer | spa | food | etc
  basePrice Decimal? @db.Decimal(10, 2)
  iconRef   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// Hotel module — count-based inventory (separate from pool villa)
// ─────────────────────────────────────────────────────────

enum HotelBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model HotelTypeMaster {
  id        String   @id @default(cuid())
  code      String   @unique // BUDGET, MIDSCALE, LUXURY, RESORT, BOUTIQUE
  nameTh    String
  nameEn    String?
  desc      String?
  iconRef   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hotel {
  id           String               @id @default(cuid())
  code         String               @unique // HTL-001
  ownerId      String
  name         Json // { th, en?, zh? }
  hotelType    String // → HotelTypeMaster.code
  description  String?              @db.Text
  address      String?              @db.Text
  phone        String?
  email        String?
  isActive     Boolean              @default(true)
  reviewStatus PropertyReviewStatus @default(PENDING)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deletedAt    DateTime?

  owner     User           @relation(fields: [ownerId], references: [id])
  roomTypes RoomType[]
  bookings  HotelBooking[]
  images    HotelImage[]

  @@index([ownerId])
  @@index([hotelType])
  @@index([reviewStatus])
  @@index([deletedAt])
}

model RoomType {
  id             String   @id @default(cuid())
  hotelId        String
  name           Json // { th: "Deluxe King" }
  description    String?  @db.Text
  pricePerNight  Decimal  @db.Decimal(10, 2)
  totalInventory Int // จำนวนห้องทั้งหมด
  maxGuests      Int      @default(2)
  bedConfig      String? // "1 King" / "2 Queen"
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hotel        Hotel              @relation(fields: [hotelId], references: [id])
  bookingLines HotelBookingLine[]
  images       RoomTypeImage[]

  @@index([hotelId])
}

model HotelImage {
  id        String  @id @default(cuid())
  hotelId   String
  url       String  @db.Text
  type      String // cover | gallery
  category  String? // exterior | lobby | pool | restaurant | room | other
  sortOrder Int     @default(0)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@index([hotelId, type])
}

model RoomTypeImage {
  id         String @id @default(cuid())
  roomTypeId String
  url        String @db.Text
  sortOrder  Int    @default(0)

  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@index([roomTypeId])
}

model HotelBooking {
  id            String             @id @default(cuid())
  code          String             @unique // HB-2026-0001
  hotelId       String
  customerName  String
  customerPhone String?
  customerEmail String?
  guestCount    Int                @default(1)
  checkin       DateTime           @db.Date
  checkout      DateTime           @db.Date
  totalAmount   Decimal            @db.Decimal(10, 2)
  status        HotelBookingStatus @default(PENDING)
  source        BookingSource      @default(OWNER_DIRECT)
  publicNote    String?            @db.Text
  internalNote  String?            @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  cancelledAt DateTime?
  deletedAt   DateTime?

  hotel Hotel              @relation(fields: [hotelId], references: [id])
  lines HotelBookingLine[]

  @@index([hotelId, checkin, checkout])
  @@index([status])
  @@index([deletedAt])
}

model HotelBookingLine {
  id            String  @id @default(cuid())
  bookingId     String
  roomTypeId    String
  roomsReserved Int
  pricePerNight Decimal @db.Decimal(10, 2) // snapshot
  lineSubtotal  Decimal @db.Decimal(10, 2)

  booking  HotelBooking @relation(fields: [bookingId], references: [id])
  roomType RoomType     @relation(fields: [roomTypeId], references: [id])

  @@index([bookingId])
  @@index([roomTypeId])
}

model HousekeepingTask {
  id         String             @id @default(cuid())
  propertyId String
  date       DateTime           @db.Date
  lineUserId String? // LINE OA user id of housekeeper
  status     HousekeepingStatus @default(PENDING)
  note       String?            @db.Text
  createdAt  DateTime           @default(now())

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId, date])
  @@index([status])
}

/// Penalty / damage items per property — listed in the House Keeper "ทำรายการ" page.
/// Used by the housekeeper to record damaged or missing items (e.g. broken lightbulb)
/// and bill the guest at the standard fee.
model PenaltyItem {
  id          String   @id @default(cuid())
  propertyId  String
  name        String
  feePerPiece Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
}
