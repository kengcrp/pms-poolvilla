{
  "name": "pms-poolvilla",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @pms/db prisma generate",
    "db:push": "pnpm --filter @pms/db prisma db push",
    "db:studio": "pnpm --filter @pms/db prisma studio",
    "db:seed": "pnpm --filter @pms/db tsx prisma/seed.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.3"
  }
}
